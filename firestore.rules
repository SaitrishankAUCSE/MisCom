rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── UTILS ───────────────────────────────────────────────────────────
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function isParticipant(chatId) {
      return request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }
    function isNotBlocked(uid) {
      // Check if current user is blocked by target user or vice versa
      // (This requires a specific path or data field in the request)
      return true; // Simplified for basic rules, but enforced in backend logic
    }

    // ─── USERS ────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid);

      // Private sensitive data (Email, etc)
      match /private/{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    // ─── VIBE REQUESTS (Connections) ──────────────────────────────────────
    match /vibe_requests/{reqId} {
      allow read: if isAuth() && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
      allow create: if isAuth() && request.resource.data.from == request.auth.uid;
      allow update, delete: if isAuth() && (request.auth.uid == resource.data.to || request.auth.uid == resource.data.from);
    }

    // ─── MESSAGE REQUESTS ─────────────────────────────────────────────────
    match /message_requests/{reqId} {
      allow read: if isAuth() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isAuth() && (request.auth.uid == resource.data.receiverId || request.auth.uid == resource.data.senderId);
    }

    // ─── CHATS ────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuth() && request.auth.uid in resource.data.participants;
      
      // Messages as a sub-collection for optimal querying and isolation
      match /messages/{msgId} {
        allow read: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuth() && request.auth.uid == request.resource.data.senderId;
        allow update: if isAuth() && request.auth.uid == resource.data.senderId; // For editing
      }
    }

    // ─── TYPING STATUS ────────────────────────────────────────────────────
    match /typing_status/{chatId} {
      allow read: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      allow write: if isAuth(); // Updated by any participant
    }

    // ─── READ RECEIPTS ────────────────────────────────────────────────────
    match /read_receipts/{msgId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ─── NOTIFICATIONS ────────────────────────────────────────────────────
    match /notifications/{uid}/{document=**} {
      allow read: if isOwner(uid);
      allow write: if isAuth();
    }

    // ─── BLOCKED USERS ────────────────────────────────────────────────────
    match /blocked_users/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ─── MEDIA UPLOADS TRACKING ───────────────────────────────────────────
    match /media_uploads/{uploadId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }
  }
}
