rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── UTILS ───────────────────────────────────────────────────────────
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function isParticipant(chatId) {
      return request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }
    function hasBlocked(ownerUid, targetUid) {
      return exists(/databases/$(database)/documents/blocked_users/$(ownerUid)) &&
        targetUid in get(/databases/$(database)/documents/blocked_users/$(ownerUid)).data.blocked;
    }
    function isNotBlocked(uid) {
      return !hasBlocked(request.auth.uid, uid) && !hasBlocked(uid, request.auth.uid);
    }

    // ─── USERS ────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid);

      // Private sensitive data (Email, etc)
      match /private/{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    // ─── VIBE REQUESTS (Connections) ──────────────────────────────────────
    match /vibe_requests/{reqId} {
      allow read: if isAuth() && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
      allow create: if isAuth() &&
        request.resource.data.from == request.auth.uid &&
        isNotBlocked(request.resource.data.to);
      allow update, delete: if isAuth() && (request.auth.uid == resource.data.to || request.auth.uid == resource.data.from);
    }

    // ─── MESSAGE REQUESTS ─────────────────────────────────────────────────
    match /message_requests/{reqId} {
      allow read: if isAuth() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow create: if isAuth() &&
        request.resource.data.senderId == request.auth.uid &&
        isNotBlocked(request.resource.data.receiverId);
      allow update, delete: if isAuth() && (request.auth.uid == resource.data.receiverId || request.auth.uid == resource.data.senderId);
    }

    // ─── CHATS ────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuth() && request.auth.uid in resource.data.participants;
      
      // Messages as a sub-collection for optimal querying and isolation
      match /messages/{msgId} {
        allow read: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuth() && request.auth.uid == request.resource.data.senderId;
        allow update: if isAuth() && request.auth.uid == resource.data.senderId; // For editing
      }
    }

    // ─── TYPING STATUS ────────────────────────────────────────────────────
    match /typing_status/{chatId} {
      allow read: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      allow create: if isAuth() &&
        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
        request.resource.data.keys().hasOnly([request.auth.uid]);
      allow update: if isAuth() &&
        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([request.auth.uid]);
      allow delete: if false;
    }

    // ─── READ RECEIPTS ────────────────────────────────────────────────────
    match /read_receipts/{msgId} {
      allow read, write: if false;
    }

    // ─── NOTIFICATIONS ────────────────────────────────────────────────────
    match /notifications/{uid} {
      allow read, write: if isOwner(uid);

      match /user_notifs/{notifId} {
        allow read, update, delete: if isOwner(uid);
        allow create: if false;
      }
    }

    // ─── BLOCKED USERS ────────────────────────────────────────────────────
    match /blocked_users/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ─── FRIENDS ──────────────────────────────────────────────────────────
    // Friends list: each user has a document with their friends array
    match /friends/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) &&
        request.resource.data.keys().hasOnly(['friends']) &&
        request.resource.data.friends is list;
      allow delete: if isOwner(uid);
    }

    // ─── FRIEND REQUESTS ──────────────────────────────────────────────────
    // Friend requests: can be created by any auth user, updated/deleted by participants
    match /friend_requests/{reqId} {
      allow read: if isAuth() && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
      allow create: if isAuth() &&
        request.resource.data.from == request.auth.uid &&
        isNotBlocked(request.resource.data.to);
      allow update, delete: if isAuth() && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
    }

    // ─── MEDIA UPLOADS TRACKING ───────────────────────────────────────────
    match /media_uploads/{uploadId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    match /reports/{reportId} {
      allow create: if isAuth() &&
        request.resource.data.reporterId == request.auth.uid &&
        request.resource.data.reportedUserId is string;
      allow read, update, delete: if request.auth.token.admin == true;
    }
  }
}
