rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: is the user authenticated?
    function isAuth() {
      return request.auth != null;
    }
    
    // Helper: is this the user's own document?
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // ─── USERS ─────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid);
    }

    // ─── VIBE REQUESTS ─────────────────────────────────────────────────────
    match /vibe_requests/{reqId} {
      allow read: if isAuth() && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
      allow create: if isAuth() && request.resource.data.from == request.auth.uid;
      allow update: if isAuth() && (request.auth.uid == resource.data.to || request.auth.uid == resource.data.from);
      allow delete: if isAuth() && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
    }

    // ─── MESSAGE REQUESTS ──────────────────────────────────────────────────
    match /message_requests/{reqId} {
      allow read: if isAuth() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isAuth() && (request.auth.uid == resource.data.receiverId || request.auth.uid == resource.data.senderId);
    }

    // ─── CHATS & MESSAGES ──────────────────────────────────────────────────
    match /chat_meta/{chatId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      allow write: if isAuth() && request.auth.uid in request.resource.data.participants;
    }

    match /chats/{chatId}/{document=**} {
      allow read: if isAuth() && (
        exists(/databases/$(database)/documents/chat_meta/$(chatId)) && 
        request.auth.uid in get(/databases/$(database)/documents/chat_meta/$(chatId)).data.participants
      );
      allow write: if isAuth() && (
        exists(/databases/$(database)/documents/chat_meta/$(chatId)) && 
        request.auth.uid in get(/databases/$(database)/documents/chat_meta/$(chatId)).data.participants
      );
    }

    // ─── NOTIFICATIONS ─────────────────────────────────────────────────────
    match /notifications/{uid}/{document=**} {
      allow read: if isOwner(uid);
      allow write: if isAuth(); // Allow other users/functions to write notifications
    }

    // ─── FRIENDS ───────────────────────────────────────────────────────────
    match /friends/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid);
    }

    // ─── BLOCKED USERS ─────────────────────────────────────────────────────
    match /blocked_users/{uid} {
      allow read, write: if isOwner(uid);
    }
  }
}
