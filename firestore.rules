rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }
    
    // Check if user is accessing their own data
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // USERS
    match /users/{userId} {
      allow read: if isAuth();
      // Only the user can create/update/delete their own profile
      allow create, update, delete: if isOwner(userId);
      
      // Prevent modifying onboarding status back to false once true
      allow update: if isOwner(userId) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['onboardingCompleted']) || request.resource.data.onboardingCompleted == true);
    }

    // CONNECTION SYSTEM / VIBE REQUESTS
    match /vibe_requests/{requestId} {
      // Can read if they are the sender or receiver
      allow read: if isAuth() && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
      // Can create if they are the sender
      allow create: if isAuth() && request.resource.data.from == request.auth.uid;
      // Can update if they are the receiver (to accept/decline) or sender (to cancel)
      allow update: if isAuth() && (resource.data.to == request.auth.uid || resource.data.from == request.auth.uid);
      allow delete: if isAuth() && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
    }
    
    // Legacy support for current implementation
    match /friend_requests/{requestId} {
      allow read, write: if isAuth();
    }

    match /friends/{userId} {
      allow read: if isAuth();
      allow write: if isOwner(userId);
    }

    // REALTIME MESSAGING (CHATS)
    match /chat_meta/{chatId} {
      // Only participants can read or update chat meta
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      // Anyone can create a chat request
      allow create: if isAuth() && request.auth.uid in request.resource.data.participants;
      // Participants can update (e.g. to accept request, change last message)
      allow update: if isAuth() && request.auth.uid in resource.data.participants;
      allow delete: if isAuth() && request.auth.uid in resource.data.participants;
    }

    match /chats/{chatId} {
      allow read, write: if isAuth(); // Root chat document might just hold subcollections
      
      // MESSAGES
      match /messages/{messageId} {
        // Can read if they are a participant in the chat (Requires fetching chat_meta, simplified for now)
        allow read: if isAuth(); 
        // Sender can create
        allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
        // Participants can update status (e.g., to "vibed")
        allow update: if isAuth(); 
        // Sender can delete
        allow delete: if isAuth() && resource.data.senderId == request.auth.uid;
      }
    }

    // PROTECTED ROOM SYSTEM
    match /rooms/{roomId} {
      // Anyone can read basic room info
      allow read: if isAuth();
      // Any authenticated user can create a room
      allow create: if isAuth() && request.resource.data.roomCreator == request.auth.uid;
      // Only creator or admins can update
      allow update: if isAuth() && (resource.data.roomCreator == request.auth.uid || request.auth.uid in resource.data.admins);
      allow delete: if isAuth() && resource.data.roomCreator == request.auth.uid;
      
      match /room_messages/{messageId} {
        // Must be member to read/write
        // Simplified rule, production would check membership array
        allow read, create: if isAuth();
        allow update, delete: if isAuth() && resource.data.senderId == request.auth.uid;
      }
    }

    // NOTIFICATIONS
    match /notifications/{userId}/user_notifs/{notificationId} {
      allow read: if isOwner(userId);
      allow create: if isAuth(); // Anyone can trigger a notification to someone else
      allow update, delete: if isOwner(userId); // Only owner can mark read/delete
    }

    // STORIES / MOMENTS
    match /stories/{storyId} {
      // Public or friends-only reads
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
  }
}
